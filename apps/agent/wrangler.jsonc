{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cfai-worker",
  "main": "src/index.ts",
  "compatibility_date": "2025-11-17",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "dev": {
    "port": 8787
  },
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  },
  // ── Workers AI + AI Gateway (caching, rate-limiting, analytics) ───────────
  // Create the gateway at: dash.cloudflare.com → AI → AI Gateway → "cfai-gateway"
  "ai": {
    "binding": "AI",
    "gateway": {
      "id": "cfai-gateway",
      "skip_cache": false,
      "cache_ttl": 3600
    }
  },
  "env": {
    "local": {
      "ai": {
        "binding": "AI"
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "CFAI_AGENT",
            "class_name": "CfaiAgent"
          }
        ]
      }
    }
  },
  // ── McpAgent Durable Object ────────────────────────────────────────────────
  "durable_objects": {
    "bindings": [
      {
        "name": "CFAI_AGENT",
        "class_name": "CfaiAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "CfaiAgent"
      ]
    }
  ]
}