{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["@cloudflare/workers-types"],
    "composite": false,
    "emitDeclarationOnly": false,
    "declarationMap": false,
    "paths": {
      "@testConfig/*": ["./testConfig/*"],
    }
  },
  "include": ["src/**/*", "testConfig/**/*"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/**/*TestFixtures.ts", "src/**/*TestLayers.ts"]
}