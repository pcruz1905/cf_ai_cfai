{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "cfai-worker-test",
    "main": "src/index.ts",
    "compatibility_date": "2025-11-17",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    // No AI binding — prevents remote proxy session in CI.
    // The AI object will be provided by miniflare's workerd runtime as a stub.
    "durable_objects": {
        "bindings": [
            {
                "name": "CFAI_AGENT",
                "class_name": "CfaiAgent"
            }
        ]
    },
    "migrations": [
        {
            "tag": "v1",
            "new_sqlite_classes": [
                "CfaiAgent"
            ]
        }
    ]
}