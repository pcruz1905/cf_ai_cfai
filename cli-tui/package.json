{
  "name": "@sellhub/cli-tui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Fancy terminal UI components for Effect-TS CLI applications",
  "scripts": {
    "build": "tsup",
    "madge": "madge --circular src/index.ts",
    "test": "vitest run --config ../../vitestSharedConfig.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint --config-path ./biome.jsonc"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "madge": "^8.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "catalog:"
  }
}
